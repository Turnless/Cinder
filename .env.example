# ==============================================================================
# AlphaWire Environment Variables Template
# ==============================================================================

# 🔷 Data Layer: SoSoValue API
# Register at https://sosovalue.com and apply via Buildathon form for API access
SOSOVALUE_API_KEY=your_sosovalue_api_key

# 🗄️ Database Layer: Turso (libSQL)
# Get credentials from your Turso dashboard (turso db show <db-name>)
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# 🟠 Execution Layer: SoDEX API
# SODEX_MASTER_PRIVATE_KEY is your main wallet private key, used only for initial 
# setup tasks like registering API keys (addAPIKey/revokeAPIKey). Do NOT use it for daily signing.
SODEX_MASTER_PRIVATE_KEY=your_evm_master_wallet_private_key_0x...
USER_WALLET_ADDRESS=your_evm_wallet_address_0x...

# The specific API Key registered on SoDEX for daily automated signing
SODEX_API_KEY_NAME=your_api_key_name
SODEX_API_KEY_PRIVATE_KEY=your_api_key_private_key_returned_from_addAPIKey

# SoDEX Gateway base URL (Testnet vs Mainnet)
# Testnet Spot: https://testnet-gw.sodex.dev/api/v1/spot
# Mainnet Spot: https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_API_BASE_URL=https://testnet-gw.sodex.dev/api/v1/spot

# 🧠 Brain Layer: OpenAI
# Required for story generation + narrative NLP classification
OPENAI_API_KEY=your_openai_api_key

# 🔔 Notification Layer: Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ⚡ Trading & Risk Settings
NARRATIVE_TRADE_THRESHOLD=80        # Minimum narrative shift confidence to trade (0-100)
MAX_ALLOCATION_PER_TRADE=0.30       # Max portion of portfolio value allowed per trade (0.0 to 1.0)
STOP_LOSS_PERCENTAGE=0.08           # Trailing stop-loss percentage (0.08 = 8%)
COOLDOWN_HOURS=48                   # Minimum hours to wait between consecutive narrative trades
AUTO_TRADE_ENABLED=false            # Master switch: set to true to enable automated trading

# 🦊 Web3 RPC & Token Settings
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/your_alchemy_key
NEXT_PUBLIC_CNDR_TOKEN_ADDRESS=0x... # Address of the deployed CinderToken contract

